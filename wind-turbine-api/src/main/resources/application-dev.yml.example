# Copy to application-dev.yml and fill in real values.
# application-dev.yml is gitignored.

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/wind_turbine_db
    username: postgres
    password: CHANGE_ME

  jpa:
    properties:
      hibernate:
        format_sql: true
    show-sql: true

jwt:
  secret-key: CHANGE_ME_MIN_32_CHARS_FOR_HMAC_SHA256
  expiration-minutes: 120

cors:
  allowed-origins: http://localhost:3000,http://localhost:5173

logging:
  level:
    com.windturbine: DEBUG
    org.hibernate.SQL: DEBUG
    org.springframework.security: DEBUG
