# ============================================================================
# Copy to `.env` on the VM (DO NOT COMMIT). docker-compose reads this file.
# ============================================================================

# ---- Spring profile ----
SPRING_PROFILES_ACTIVE=prod

# ---- Database (existing TimescaleDB on the VM) ----
DB_URL=jdbc:postgresql://10.0.3.2:5432/windguard
DB_USERNAME=windguard_user
DB_PASSWORD=replace-me

# Pool sizing — tune to your DB max_connections budget.
DB_POOL_MAX=20
DB_POOL_MIN=5

# ---- JWT ----
# Generate with: openssl rand -base64 48 | tr -d '\n' | cut -c1-64
JWT_SECRET_KEY=replace-with-64-char-random-string
JWT_ISSUER=WindTurbineAPI
JWT_AUDIENCE=WindTurbineDashboard
JWT_EXPIRATION_MINUTES=60

# ---- CORS ----
CORS_ALLOWED_ORIGINS=https://dashboard.example.com

# ---- HTTP ----
SERVER_PORT=8080
TOMCAT_THREADS_MAX=200
TOMCAT_THREADS_MIN=10

# ---- Actuator (kept internal — never expose port 8081 to the public) ----
MANAGEMENT_PORT=8081

# ---- Seed ----
APP_SEEDER_ENABLED=true

# ---- JVM ----
# Hard heap cap so the JVM respects container memory.
# Boot ergonomics will pick a default of 50% RAM; uncomment to override.
# JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:+ExitOnOutOfMemoryError
